{
  "irc": {
    "host": "irc.libera.chat",
    "port": 6697,
    "tls": true,
    "nick": "Hexbot",
    "username": "hexbot",
    "realname": "Hexbot IRC Bot",
    "channels": ["#hexbot-test"]
  },
  "owner": {
    "handle": "admin",
    "hostmask": "*!yourident@your.host.here"
  },
  "identity": {
    "method": "hostmask",
    "require_acc_for": ["+o", "+n"]
  },
  "services": {
    "type": "anope",
    "nickserv": "NickServ",
    "password": "",
    "sasl": true
  },
  "database": "./data/hexbot.db",
  "pluginDir": "./plugins",
  "logging": {
    "level": "info",
    "mod_actions": true
  },
  "queue": {
    "rate": 1,
    "burst": 5
  },
  "dcc": {
    "enabled": false,
    "ip": "0.0.0.0",
    "port_range": [50000, 50010],
    "require_flags": "m",
    "max_sessions": 5,
    "idle_timeout_ms": 300000,
    "nickserv_verify": false
  },
  "proxy": {
    "host": "127.0.0.1",
    "port": 9050
  },
  "quit_message": "Hexbot v0.1.0"
}
