{
  "irc": {
    "host": "irc.rizon.net",
    "port": 6697,
    "tls": true,
    "nick": "Hexbot",
    "username": "hexbot",
    "realname": "HexBot IRC Bot",
    "channels": ["#hexbot", { "name": "#secret", "key": "password" }],
    "_comment_tls_verify": "tls_verify defaults to true (validates server cert). Set to false only for networks with self-signed certs — disables certificate validation",
    "_comment_tls_cert": "Optional: set tls_cert + tls_key and sasl_mechanism=EXTERNAL for CertFP auth (no password needed)"
  },
  "owner": {
    "handle": "admin",
    "hostmask": "*!yourident@your.host.here"
  },
  "identity": {
    "method": "hostmask",
    "require_acc_for": ["+o", "+n"]
  },
  "services": {
    "type": "anope",
    "nickserv": "NickServ",
    "password": "",
    "sasl": true,
    "sasl_mechanism": "PLAIN"
  },
  "database": "./data/hexbot.db",
  "pluginDir": "./plugins",
  "logging": {
    "level": "info",
    "mod_actions": true
  },
  "queue": {
    "rate": 1,
    "burst": 5
  },
  "flood": {
    "pub": { "count": 5, "window": 10 },
    "msg": { "count": 5, "window": 10 }
  },
  "dcc": {
    "enabled": false,
    "ip": "0.0.0.0",
    "port_range": [49152, 49171],
    "require_flags": "m",
    "max_sessions": 5,
    "idle_timeout_ms": 300000,
    "nickserv_verify": false
  },
  "proxy": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 9050
  },
  "quit_message": "HexBot"
}
